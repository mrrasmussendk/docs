{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vitruvian",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Repository",
          "href": "https://github.com/mrrasmussendk/Vitruvian",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Discussions",
          "href": "https://github.com/mrrasmussendk/Vitruvian/discussions",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
      "light": "/logo/light.svg",
      "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
          "label": "GitHub",
          "href": "https://github.com/mrrasmussendk/Vitruvian"
        }
      ],
      "primary": {
        "type": "button",
        "label": "Report an issue",
        "href": "https://github.com/mrrasmussendk/Vitruvian/issues"
      }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mrrasmussendk/Vitruvian"
    }
  }
}
